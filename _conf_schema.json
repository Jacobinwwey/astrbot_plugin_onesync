{
  "enabled": {
    "description": "启用 OneSync 插件",
    "type": "bool",
    "default": true
  },
  "software_overview": {
    "description": "软件与版本总览（自动生成）",
    "type": "template_list",
    "hint": "此字段由插件自动刷新，每条为一个软件目标的版本摘要。只读展示（不支持手动编辑），支持表格/卡片/紧凑视图、状态筛选和主题切换。",
    "default": [],
    "templates": {
      "software_item": {
        "name": "软件版本项",
        "hint": "自动生成项，请勿手动编辑。",
        "items": {
          "software_name": {
            "type": "string",
            "description": "软件名称",
            "default": ""
          },
          "current_version": {
            "type": "string",
            "description": "当前版本",
            "default": "-"
          },
          "latest_version": {
            "type": "string",
            "description": "最新版本",
            "default": "-"
          },
          "enabled": {
            "type": "string",
            "description": "是否启用",
            "default": "是"
          },
          "strategy": {
            "type": "string",
            "description": "更新策略",
            "default": "command"
          },
          "last_checked_at": {
            "type": "string",
            "description": "最近检查时间",
            "default": "-"
          }
        }
      }
    }
  },
  "web_admin": {
    "description": "WebUI 管理端配置",
    "type": "object",
    "hint": "启用后可通过浏览器打开 OneSync 管理页面，在不修改 AstrBot Dashboard 源码的前提下获得完整前端交互。",
    "items": {
      "enabled": {
        "description": "启用 WebUI 管理端",
        "type": "bool",
        "default": false
      },
      "host": {
        "description": "监听地址",
        "type": "string",
        "default": "127.0.0.1",
        "hint": "建议默认 127.0.0.1（仅本机访问）。如需局域网访问可设为 0.0.0.0。"
      },
      "port": {
        "description": "监听端口",
        "type": "int",
        "default": 8099,
        "hint": "WebUI 服务端口。",
        "slider": {
          "min": 1024,
          "max": 65535,
          "step": 1
        }
      },
      "password": {
        "description": "WebUI 访问密码（可选）",
        "type": "string",
        "default": "",
        "hint": "留空表示无需登录；设置后访问 /api 需要先登录。"
      }
    }
  },
  "web_admin_url": {
    "description": "WebUI 访问地址（自动生成）",
    "type": "string",
    "default": "",
    "hint": "由插件自动写入，通常不需要手动修改。"
  },
  "poll_interval_minutes": {
    "description": "定时轮询间隔（分钟）",
    "type": "int",
    "hint": "插件后台循环的执行间隔。建议 5-60 分钟。",
    "default": 30
  },
  "default_check_interval_hours": {
    "description": "默认目标检查间隔（小时）",
    "type": "float",
    "hint": "当某个目标未配置 check_interval_hours 时使用此值。",
    "default": 24
  },
  "auto_update_on_schedule": {
    "description": "定时任务发现新版本后自动更新",
    "type": "bool",
    "default": true
  },
  "notify_admin_on_schedule": {
    "description": "定时任务后通知管理员",
    "type": "bool",
    "default": true
  },
  "notify_on_schedule_noop": {
    "description": "无更新/无异常时也通知管理员",
    "type": "bool",
    "hint": "关闭后仅在发生更新或失败时通知。",
    "default": false
  },
  "dry_run": {
    "description": "演练模式（不真正执行更新命令）",
    "type": "bool",
    "condition": {
      "target_config_mode": "developer"
    },
    "default": false
  },
  "env_check_timeout_s": {
    "description": "环境检测命令超时（秒）",
    "type": "int",
    "hint": "用于 /updater env 命令，检查 command -v 与 --version。",
    "condition": {
      "target_config_mode": "developer"
    },
    "default": 8
  },
  "admin_sid_list": {
    "description": "管理员 SID 列表",
    "type": "list",
    "hint": "定时任务通知将发送到这些 SID。",
    "default": []
  },
  "target_config_mode": {
    "description": "目标配置模式",
    "type": "string",
    "default": "human",
    "options": [
      "human",
      "developer"
    ],
    "hint": "human：面向用户的简洁配置；developer：展开高级参数并直接编辑 targets_json。"
  },
  "human_targets": {
    "type": "template_list",
    "description": "软件目标列表（人类交互模式，无槽位上限）",
    "hint": "仅在 target_config_mode=human 时生效。这里保留常用基础项；镜像、超时、正则等高级项请切换 developer 模式配置。",
    "condition": {
      "target_config_mode": "human"
    },
    "default": [],
    "templates": {
      "cargo_path_git": {
        "name": "Cargo/Git 软件",
        "hint": "适用于本地 git 仓库 + cargo install --path 这类软件。",
        "items": {
          "name": {
            "type": "string",
            "description": "目标名称（必填，唯一）",
            "default": ""
          },
          "enabled": {
            "type": "bool",
            "description": "启用该目标",
            "default": true
          },
          "strategy": {
            "type": "string",
            "description": "策略标识（无需修改）",
            "default": "cargo_path_git"
          },
          "check_interval_hours": {
            "type": "float",
            "description": "检查间隔（小时）",
            "default": 12
          },
          "repo_path": {
            "type": "string",
            "description": "本地仓库路径",
            "default": ""
          },
          "binary_path": {
            "type": "string",
            "description": "可执行文件路径",
            "default": ""
          },
          "upstream_repo": {
            "type": "string",
            "description": "上游仓库 URL",
            "default": ""
          },
          "current_version_cmd": {
            "type": "string",
            "description": "当前版本命令（可选，默认使用 binary_path --version）",
            "default": ""
          },
          "verify_cmd": {
            "type": "string",
            "description": "更新后验证命令",
            "default": ""
          }
        }
      },
      "system_package": {
        "name": "系统包管理器软件",
        "hint": "适用于 apt/yum/dnf/pacman/zypper/choco/winget/brew 等系统包管理器。",
        "items": {
          "name": {
            "type": "string",
            "description": "目标名称（必填，唯一）",
            "default": ""
          },
          "enabled": {
            "type": "bool",
            "description": "启用该目标",
            "default": true
          },
          "strategy": {
            "type": "string",
            "description": "策略标识（无需修改）",
            "default": "system_package"
          },
          "check_interval_hours": {
            "type": "float",
            "description": "检查间隔（小时）",
            "default": 12
          },
          "manager": {
            "type": "string",
            "description": "包管理器",
            "default": "apt_get",
            "hint": "支持 apt_get/yum/dnf/pacman/zypper/choco/winget/brew"
          },
          "package_name": {
            "type": "string",
            "description": "包名（为空时默认使用 name）",
            "default": ""
          },
          "require_sudo": {
            "type": "bool",
            "description": "更新命令是否自动加 sudo 前缀",
            "default": true
          },
          "sudo_prefix": {
            "type": "string",
            "description": "sudo 前缀命令",
            "default": "sudo"
          },
          "current_version_cmd": {
            "type": "string",
            "description": "当前版本命令（可选，留空使用内置命令）",
            "default": ""
          },
          "latest_version_cmd": {
            "type": "string",
            "description": "最新版本命令（可选，留空使用内置命令）",
            "default": ""
          },
          "update_commands": {
            "type": "list",
            "description": "更新命令列表（可选，留空使用内置命令）",
            "default": []
          },
          "verify_cmd": {
            "type": "string",
            "description": "更新后验证命令",
            "default": ""
          }
        }
      },
      "command": {
        "name": "命令型软件",
        "hint": "适用于任意软件：通过命令读取版本并执行更新脚本。",
        "items": {
          "name": {
            "type": "string",
            "description": "目标名称（必填，唯一）",
            "default": ""
          },
          "enabled": {
            "type": "bool",
            "description": "启用该目标",
            "default": true
          },
          "strategy": {
            "type": "string",
            "description": "策略标识（无需修改）",
            "default": "command"
          },
          "check_interval_hours": {
            "type": "float",
            "description": "检查间隔（小时）",
            "default": 24
          },
          "current_version_cmd": {
            "type": "string",
            "description": "当前版本命令",
            "default": ""
          },
          "latest_version_cmd": {
            "type": "string",
            "description": "最新版本命令",
            "default": ""
          },
          "update_commands": {
            "type": "list",
            "description": "更新命令列表",
            "default": []
          },
          "verify_cmd": {
            "type": "string",
            "description": "更新后验证命令",
            "default": ""
          }
        }
      }
    }
  },
  "targets_json": {
    "description": "开发者设置（targets_json）",
    "type": "text",
    "editor_mode": true,
    "editor_language": "json",
    "hint": "仅在 target_config_mode=developer 时生效。可配置镜像策略、超时、正则、附加命令等完整高级参数；strategy 支持 cargo_path_git / command / system_package。",
    "condition": {
      "target_config_mode": "developer"
    },
    "default": "{\n  \"zeroclaw\": {\n    \"enabled\": true,\n    \"strategy\": \"cargo_path_git\",\n    \"check_interval_hours\": 12,\n    \"repo_path\": \"/path/to/zeroclaw\",\n    \"binary_path\": \"/path/to/.cargo/bin/zeroclaw\",\n    \"branch\": \"\",\n    \"auto_add_safe_directory\": true,\n    \"upstream_repo\": \"https://github.com/zeroclaw-labs/zeroclaw.git\",\n    \"mirror_prefixes\": [\n      \"\",\n      \"https://edgeone.gh-proxy.com/\",\n      \"https://hk.gh-proxy.com/\",\n      \"https://gh-proxy.com/\",\n      \"https://gh.llkk.cc/\",\n      \"https://ghfast.top/\"\n    ],\n    \"remote_candidates\": [],\n    \"append_default_mirror_prefixes\": true,\n    \"probe_remotes\": true,\n    \"probe_timeout_s\": 15,\n    \"probe_parallelism\": 4,\n    \"probe_cache_ttl_minutes\": 30,\n    \"build_commands\": [\n      \"cargo install --path {repo_path}\"\n    ],\n    \"verify_cmd\": \"{binary_path} --version\",\n    \"check_timeout_s\": 120,\n    \"update_timeout_s\": 1800,\n    \"verify_timeout_s\": 120,\n    \"current_version_pattern\": \"(\\\\d+\\\\.\\\\d+\\\\.\\\\d+(?:[-+][0-9A-Za-z.\\\\-]+)?)\"\n  }\n}"
  },
  "software_catalog": {
    "description": "软件资产目录（统一管理）",
    "type": "text",
    "editor_mode": true,
    "editor_language": "json",
    "hint": "JSON 数组。用于声明受管软件资产（cli/gui/claw）及其本地探测信息和 skill 根目录。",
    "default": "[]"
  },
  "skill_catalog": {
    "description": "Skill 资产目录（统一管理）",
    "type": "text",
    "editor_mode": true,
    "editor_language": "json",
    "hint": "JSON 数组。用于声明可管理的 skills、来源路径和兼容软件类型。",
    "default": "[]"
  },
  "skill_bindings": {
    "description": "软件与 Skill 绑定关系（统一管理）",
    "type": "text",
    "editor_mode": true,
    "editor_language": "json",
    "hint": "JSON 数组。每项包含 software_id、skill_id、scope(global/workspace)。",
    "default": "[]"
  },
  "skill_management_mode": {
    "description": "Skills 管理模式",
    "type": "string",
    "hint": "可选 npx / filesystem / hybrid。推荐 npx（基于 npx skills ls）。",
    "default": "npx"
  },
  "npx_skills_command": {
    "description": "npx Skills 命令",
    "type": "string",
    "hint": "默认 npx，可改为 pnpm dlx 或其他兼容命令前缀。",
    "default": "npx"
  },
  "npx_skills_timeout_s": {
    "description": "npx Skills 探测超时（秒）",
    "type": "int",
    "default": 12
  },
  "npx_skills_include_project": {
    "description": "npx Skills 包含项目级",
    "type": "bool",
    "default": true
  },
  "npx_skills_include_global": {
    "description": "npx Skills 包含全局级",
    "type": "bool",
    "default": true
  },
  "npx_skills_workdir": {
    "description": "npx Skills 工作目录",
    "type": "string",
    "hint": "为空时使用插件运行目录。项目级 skills 将基于此目录解析。",
    "default": ""
  },
  "auto_discover_cli": {
    "description": "自动发现 PATH 中 CLI 软件",
    "type": "bool",
    "default": true
  },
  "auto_discover_cli_max": {
    "description": "自动发现 CLI 数量上限",
    "type": "int",
    "default": 120
  },
  "auto_cli_only_known": {
    "description": "仅发现已知可调用 Skills 的软件",
    "type": "bool",
    "default": true
  },
  "auto_cli_include_commands": {
    "description": "额外包含 CLI 命令",
    "type": "list",
    "hint": "命令名列表。即使默认未扫描到也会优先尝试。",
    "default": []
  },
  "auto_cli_exclude_commands": {
    "description": "排除 CLI 命令",
    "type": "list",
    "hint": "命令名列表。会从自动发现结果中过滤。",
    "default": []
  }
}
