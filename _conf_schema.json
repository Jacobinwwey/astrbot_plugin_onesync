{
  "enabled": {
    "description": "启用 OneSync 插件",
    "type": "bool",
    "default": true
  },
  "software_overview": {
    "description": "软件与版本总览（自动生成）",
    "type": "list",
    "hint": "此字段由插件自动刷新，每条为一个软件目标的版本摘要。建议勿手动修改。",
    "default": []
  },
  "poll_interval_minutes": {
    "description": "定时轮询间隔（分钟）",
    "type": "int",
    "hint": "插件后台循环的执行间隔。建议 5-60 分钟。",
    "default": 30
  },
  "default_check_interval_hours": {
    "description": "默认目标检查间隔（小时）",
    "type": "float",
    "hint": "当某个目标未配置 check_interval_hours 时使用此值。",
    "default": 24
  },
  "auto_update_on_schedule": {
    "description": "定时任务发现新版本后自动更新",
    "type": "bool",
    "default": true
  },
  "notify_admin_on_schedule": {
    "description": "定时任务后通知管理员",
    "type": "bool",
    "default": true
  },
  "notify_on_schedule_noop": {
    "description": "无更新/无异常时也通知管理员",
    "type": "bool",
    "hint": "关闭后仅在发生更新或失败时通知。",
    "default": false
  },
  "dry_run": {
    "description": "演练模式（不真正执行更新命令）",
    "type": "bool",
    "condition": {
      "target_config_mode": "developer"
    },
    "default": false
  },
  "env_check_timeout_s": {
    "description": "环境检测命令超时（秒）",
    "type": "int",
    "hint": "用于 /updater env 命令，检查 command -v 与 --version。",
    "condition": {
      "target_config_mode": "developer"
    },
    "default": 8
  },
  "admin_sid_list": {
    "description": "管理员 SID 列表",
    "type": "list",
    "hint": "定时任务通知将发送到这些 SID。",
    "default": []
  },
  "target_config_mode": {
    "description": "目标配置模式",
    "type": "string",
    "default": "human",
    "options": [
      "human",
      "developer"
    ],
    "hint": "human：面向用户的简洁配置；developer：展开高级参数并直接编辑 targets_json。"
  },
  "human_targets": {
    "type": "template_list",
    "description": "软件目标列表（人类交互模式，无槽位上限）",
    "hint": "仅在 target_config_mode=human 时生效。这里保留常用基础项；镜像、超时、正则等高级项请切换 developer 模式配置。",
    "condition": {
      "target_config_mode": "human"
    },
    "default": [],
    "templates": {
      "cargo_path_git": {
        "name": "Cargo/Git 软件",
        "hint": "适用于本地 git 仓库 + cargo install --path 这类软件。",
        "items": {
          "name": {
            "type": "string",
            "description": "目标名称（必填，唯一）",
            "default": ""
          },
          "enabled": {
            "type": "bool",
            "description": "启用该目标",
            "default": true
          },
          "strategy": {
            "type": "string",
            "description": "策略标识（无需修改）",
            "default": "cargo_path_git"
          },
          "check_interval_hours": {
            "type": "float",
            "description": "检查间隔（小时）",
            "default": 12
          },
          "repo_path": {
            "type": "string",
            "description": "本地仓库路径",
            "default": ""
          },
          "binary_path": {
            "type": "string",
            "description": "可执行文件路径",
            "default": ""
          },
          "upstream_repo": {
            "type": "string",
            "description": "上游仓库 URL",
            "default": ""
          },
          "current_version_cmd": {
            "type": "string",
            "description": "当前版本命令（可选，默认使用 binary_path --version）",
            "default": ""
          },
          "verify_cmd": {
            "type": "string",
            "description": "更新后验证命令",
            "default": ""
          }
        }
      },
      "command": {
        "name": "命令型软件",
        "hint": "适用于任意软件：通过命令读取版本并执行更新脚本。",
        "items": {
          "name": {
            "type": "string",
            "description": "目标名称（必填，唯一）",
            "default": ""
          },
          "enabled": {
            "type": "bool",
            "description": "启用该目标",
            "default": true
          },
          "strategy": {
            "type": "string",
            "description": "策略标识（无需修改）",
            "default": "command"
          },
          "check_interval_hours": {
            "type": "float",
            "description": "检查间隔（小时）",
            "default": 24
          },
          "current_version_cmd": {
            "type": "string",
            "description": "当前版本命令",
            "default": ""
          },
          "latest_version_cmd": {
            "type": "string",
            "description": "最新版本命令",
            "default": ""
          },
          "update_commands": {
            "type": "list",
            "description": "更新命令列表",
            "default": []
          },
          "verify_cmd": {
            "type": "string",
            "description": "更新后验证命令",
            "default": ""
          }
        }
      }
    }
  },
  "targets_json": {
    "description": "开发者设置（targets_json）",
    "type": "text",
    "editor_mode": true,
    "editor_language": "json",
    "hint": "仅在 target_config_mode=developer 时生效。可配置镜像策略、超时、正则、附加命令等完整高级参数。",
    "condition": {
      "target_config_mode": "developer"
    },
    "default": "{\n  \"zeroclaw\": {\n    \"enabled\": true,\n    \"strategy\": \"cargo_path_git\",\n    \"check_interval_hours\": 12,\n    \"repo_path\": \"/path/to/zeroclaw\",\n    \"binary_path\": \"/path/to/.cargo/bin/zeroclaw\",\n    \"branch\": \"\",\n    \"auto_add_safe_directory\": true,\n    \"upstream_repo\": \"https://github.com/zeroclaw-labs/zeroclaw.git\",\n    \"mirror_prefixes\": [\n      \"\",\n      \"https://edgeone.gh-proxy.com/\",\n      \"https://hk.gh-proxy.com/\",\n      \"https://gh-proxy.com/\",\n      \"https://gh.llkk.cc/\",\n      \"https://ghfast.top/\"\n    ],\n    \"remote_candidates\": [],\n    \"append_default_mirror_prefixes\": true,\n    \"probe_remotes\": true,\n    \"probe_timeout_s\": 15,\n    \"probe_parallelism\": 4,\n    \"probe_cache_ttl_minutes\": 30,\n    \"build_commands\": [\n      \"cargo install --path {repo_path}\"\n    ],\n    \"verify_cmd\": \"{binary_path} --version\",\n    \"check_timeout_s\": 120,\n    \"update_timeout_s\": 1800,\n    \"verify_timeout_s\": 120,\n    \"current_version_pattern\": \"(\\\\d+\\\\.\\\\d+\\\\.\\\\d+(?:[-+][0-9A-Za-z.\\\\-]+)?)\"\n  }\n}"
  }
}
