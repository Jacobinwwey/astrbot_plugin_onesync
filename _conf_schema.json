{
  "enabled": {
    "description": "启用 OneSync 插件",
    "type": "bool",
    "default": true
  },
  "poll_interval_minutes": {
    "description": "定时轮询间隔（分钟）",
    "type": "int",
    "hint": "插件后台循环的执行间隔。建议 5-60 分钟。",
    "default": 30
  },
  "default_check_interval_hours": {
    "description": "默认目标检查间隔（小时）",
    "type": "float",
    "hint": "当某个目标未配置 check_interval_hours 时使用此值。",
    "default": 24
  },
  "auto_update_on_schedule": {
    "description": "定时任务发现新版本后自动更新",
    "type": "bool",
    "default": true
  },
  "notify_admin_on_schedule": {
    "description": "定时任务后通知管理员",
    "type": "bool",
    "default": true
  },
  "notify_on_schedule_noop": {
    "description": "无更新/无异常时也通知管理员",
    "type": "bool",
    "hint": "关闭后仅在发生更新或失败时通知。",
    "default": false
  },
  "dry_run": {
    "description": "演练模式（不真正执行更新命令）",
    "type": "bool",
    "default": false
  },
  "admin_sid_list": {
    "description": "管理员 SID 列表",
    "type": "list",
    "hint": "定时任务通知将发送到这些 SID。",
    "default": []
  },
  "target_config_mode": {
    "description": "目标配置模式",
    "type": "string",
    "default": "human",
    "options": [
      "human",
      "developer"
    ],
    "hint": "human：使用下方“软件目标列表”可视化配置；developer：使用 targets_json 高级模式。"
  },
  "human_targets": {
    "type": "template_list",
    "description": "软件目标列表（人类交互模式，无槽位上限）",
    "hint": "仅在 target_config_mode=human 时生效。点击“添加条目”可无限新增软件目标；已配置目标会在这里逐条显示。",
    "default": [],
    "templates": {
      "cargo_path_git": {
        "name": "Cargo/Git 软件",
        "hint": "适用于本地 git 仓库 + cargo install --path 这类软件。",
        "items": {
          "name": {
            "type": "string",
            "description": "目标名称（必填，唯一）",
            "default": ""
          },
          "enabled": {
            "type": "bool",
            "description": "启用该目标",
            "default": true
          },
          "strategy": {
            "type": "string",
            "description": "策略标识（无需修改）",
            "default": "cargo_path_git"
          },
          "check_interval_hours": {
            "type": "float",
            "description": "检查间隔（小时）",
            "default": 12
          },
          "repo_path": {
            "type": "string",
            "description": "本地仓库路径",
            "default": ""
          },
          "binary_path": {
            "type": "string",
            "description": "可执行文件路径",
            "default": ""
          },
          "branch": {
            "type": "string",
            "description": "分支名（留空自动检测）",
            "default": ""
          },
          "auto_add_safe_directory": {
            "type": "bool",
            "description": "自动添加 git safe.directory",
            "default": true
          },
          "upstream_repo": {
            "type": "string",
            "description": "上游仓库 URL",
            "default": ""
          },
          "mirror_prefixes": {
            "type": "list",
            "description": "镜像前缀列表",
            "default": [
              "",
              "https://edgeone.gh-proxy.com/",
              "https://hk.gh-proxy.com/",
              "https://gh-proxy.com/",
              "https://gh.llkk.cc/",
              "https://ghfast.top/"
            ]
          },
          "remote_candidates": {
            "type": "list",
            "description": "额外远端候选地址",
            "default": []
          },
          "append_default_mirror_prefixes": {
            "type": "bool",
            "description": "自动补齐内置 GitHub 镜像前缀",
            "default": true
          },
          "probe_remotes": {
            "type": "bool",
            "description": "更新前自动测速远端",
            "default": true
          },
          "probe_timeout_s": {
            "type": "int",
            "description": "单远端测速超时（秒）",
            "default": 15
          },
          "probe_parallelism": {
            "type": "int",
            "description": "并发测速数",
            "default": 4
          },
          "probe_cache_ttl_minutes": {
            "type": "float",
            "description": "测速缓存 TTL（分钟）",
            "default": 30
          },
          "build_commands": {
            "type": "list",
            "description": "构建命令列表",
            "default": [
              "cargo install --path {repo_path}"
            ]
          },
          "current_version_cmd": {
            "type": "string",
            "description": "当前版本命令（可选）",
            "default": ""
          },
          "current_version_pattern": {
            "type": "string",
            "description": "当前版本提取正则",
            "default": "(\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.\\-]+)?)"
          },
          "verify_cmd": {
            "type": "string",
            "description": "更新后验证命令",
            "default": ""
          },
          "check_timeout_s": {
            "type": "int",
            "description": "检查超时（秒）",
            "default": 120
          },
          "update_timeout_s": {
            "type": "int",
            "description": "更新超时（秒）",
            "default": 1800
          },
          "verify_timeout_s": {
            "type": "int",
            "description": "验证超时（秒）",
            "default": 120
          }
        }
      },
      "command": {
        "name": "命令型软件",
        "hint": "适用于任意软件：通过命令读取版本并执行更新脚本。",
        "items": {
          "name": {
            "type": "string",
            "description": "目标名称（必填，唯一）",
            "default": ""
          },
          "enabled": {
            "type": "bool",
            "description": "启用该目标",
            "default": true
          },
          "strategy": {
            "type": "string",
            "description": "策略标识（无需修改）",
            "default": "command"
          },
          "check_interval_hours": {
            "type": "float",
            "description": "检查间隔（小时）",
            "default": 24
          },
          "current_version_cmd": {
            "type": "string",
            "description": "当前版本命令",
            "default": ""
          },
          "current_version_pattern": {
            "type": "string",
            "description": "当前版本提取正则",
            "default": "(\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.\\-]+)?)"
          },
          "latest_version_cmd": {
            "type": "string",
            "description": "最新版本命令",
            "default": ""
          },
          "latest_version_pattern": {
            "type": "string",
            "description": "最新版本提取正则",
            "default": "(\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.\\-]+)?)"
          },
          "update_commands": {
            "type": "list",
            "description": "更新命令列表",
            "default": []
          },
          "verify_cmd": {
            "type": "string",
            "description": "更新后验证命令",
            "default": ""
          },
          "check_timeout_s": {
            "type": "int",
            "description": "检查超时（秒）",
            "default": 120
          },
          "update_timeout_s": {
            "type": "int",
            "description": "更新超时（秒）",
            "default": 900
          },
          "verify_timeout_s": {
            "type": "int",
            "description": "验证超时（秒）",
            "default": 120
          }
        }
      }
    }
  },
  "targets_json": {
    "description": "更新目标配置（JSON，高级开发者模式）",
    "type": "text",
    "editor_mode": true,
    "editor_language": "json",
    "hint": "仅在 target_config_mode=developer 时生效。支持任意数量目标与完整字段。",
    "default": "{\n  \"zeroclaw\": {\n    \"enabled\": true,\n    \"strategy\": \"cargo_path_git\",\n    \"check_interval_hours\": 12,\n    \"repo_path\": \"/home/jacob/zeroclaw\",\n    \"binary_path\": \"/root/.cargo/bin/zeroclaw\",\n    \"branch\": \"\",\n    \"auto_add_safe_directory\": true,\n    \"upstream_repo\": \"https://github.com/zeroclaw-labs/zeroclaw.git\",\n    \"mirror_prefixes\": [\n      \"\",\n      \"https://edgeone.gh-proxy.com/\",\n      \"https://hk.gh-proxy.com/\",\n      \"https://gh-proxy.com/\",\n      \"https://gh.llkk.cc/\",\n      \"https://ghfast.top/\"\n    ],\n    \"remote_candidates\": [],\n    \"append_default_mirror_prefixes\": true,\n    \"probe_remotes\": true,\n    \"probe_timeout_s\": 15,\n    \"probe_parallelism\": 4,\n    \"probe_cache_ttl_minutes\": 30,\n    \"build_commands\": [\n      \"cargo install --path {repo_path}\"\n    ],\n    \"verify_cmd\": \"{binary_path} --version\",\n    \"check_timeout_s\": 120,\n    \"update_timeout_s\": 1800,\n    \"verify_timeout_s\": 120,\n    \"current_version_pattern\": \"(\\\\d+\\\\.\\\\d+\\\\.\\\\d+(?:[-+][0-9A-Za-z.\\\\-]+)?)\"\n  }\n}"
  }
}
